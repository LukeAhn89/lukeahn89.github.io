---
type Props = {
  id: string;
  eyebrow: string;
  title: string;
  description?: string;
};

const { id, eyebrow, title, description } = Astro.props;
---

<section
  id={id}
  class="resume-section mx-auto grid max-w-7xl gap-8 border-b border-neutral-200 px-5 py-14 sm:px-8 lg:grid-cols-[280px_1fr] lg:px-10 lg:py-20"
  data-reveal
>
  <div>
    <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-lime-700">{eyebrow}</p>
    <h2 class="text-3xl font-black tracking-normal text-neutral-950 sm:text-4xl">{title}</h2>
    {description && <p class="mt-4 text-sm leading-6 text-neutral-500">{description}</p>}
  </div>
  <div><slot /></div>
</section>
