---
import { profile } from "../data/resume";
---

<header class="relative overflow-hidden border-b border-neutral-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-8 sm:px-8 lg:grid-cols-[1fr_340px] lg:px-10 lg:py-12">
    <div class="flex min-h-[520px] flex-col justify-between gap-12 lg:min-h-[600px]">
      <nav class="no-print flex items-center justify-between gap-4">
        <a class="text-sm font-semibold tracking-wide text-neutral-950" href="/">Ahn Jungmin</a>
        <div class="flex items-center gap-3">
          {profile.links.map((link) => (
            <a
              class="hidden rounded-full border border-neutral-200 px-4 py-2 text-sm font-medium text-neutral-700 transition hover:border-neutral-950 hover:text-neutral-950 sm:inline-flex"
              href={link.href}
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </nav>

      <section class="max-w-4xl">
        <p class="mb-5 inline-flex rounded-full border border-neutral-200 px-3 py-1 text-xs font-bold uppercase tracking-[0.22em] text-neutral-500">
          Resume / Software Engineer
        </p>
        <h1 class="max-w-5xl text-[clamp(3rem,8vw,8.8rem)] font-black leading-[0.9] tracking-normal text-neutral-950">
          안정민
        </h1>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-base font-semibold text-neutral-950 sm:text-lg">
          <span>{profile.title}</span>
          <span class="h-2 w-2 rounded-full bg-lime-300"></span>
          <span>{profile.location}</span>
        </div>
        <p class="mt-8 max-w-3xl text-lg leading-8 text-neutral-700 sm:text-xl sm:leading-9">
          {profile.summary}
        </p>
      </section>

      <div class="header-principles grid gap-4 sm:grid-cols-3">
        {profile.principles.map((principle, index) => (
          <div class="rounded-[6px] border border-neutral-200 bg-neutral-50 p-5">
            <p class="mb-6 text-xs font-bold text-neutral-400">0{index + 1}</p>
            <p class="text-base font-semibold leading-7 text-neutral-950">{principle}</p>
          </div>
        ))}
      </div>
    </div>

    <aside class="flex flex-col justify-between rounded-[8px] bg-neutral-950 p-5 text-white lg:min-h-[600px]">
      <div class="overflow-hidden rounded-[6px] bg-neutral-800">
        <img class="aspect-square h-full w-full object-cover object-[50%_18%]" src={profile.image} alt={`${profile.name} 프로필 사진`} />
      </div>
      <div class="mt-8 space-y-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-lime-300">Contact</p>
          <a class="mt-3 block break-all text-lg font-semibold text-white" href={`mailto:${profile.email}`}>{profile.email}</a>
          <a class="mt-2 block text-lg font-semibold text-white" href={`https://github.com/${profile.github}`} target="_blank" rel="noreferrer">
            github.com/{profile.github}
          </a>
        </div>
        <div class="rounded-[6px] border border-white/15 p-4">
          <p class="text-sm leading-6 text-neutral-300">
            LLM agent systems, generative content workflows, backend engineering, and product reliability.
          </p>
        </div>
      </div>
    </aside>
  </div>
</header>
