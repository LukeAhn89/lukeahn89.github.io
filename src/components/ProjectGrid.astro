---
import type { ResumeItem } from "../data/resume";

type Props = {
  items: ResumeItem[];
};

const { items } = Astro.props;
---

<div class="project-grid grid gap-4 lg:grid-cols-2">
  {items.map((item) => (
    <article class="rounded-[8px] border border-neutral-200 bg-white p-6 transition hover:-translate-y-1 hover:border-neutral-950 hover:shadow-[0_24px_80px_rgba(0,0,0,0.08)]" data-reveal>
      <div class="flex min-h-20 flex-col justify-between gap-4">
        <div>
          <p class="text-sm font-bold text-lime-700">{item.period ?? "Project"}</p>
          <h3 class="mt-2 text-2xl font-black tracking-normal text-neutral-950">{item.name}</h3>
          {item.summary && <p class="mt-3 text-sm leading-6 text-neutral-500">{item.summary}</p>}
        </div>
      </div>
      <ul class="mt-6 space-y-2 text-sm leading-6 text-neutral-700">
        {item.bullets.map((bullet) => (
          <li class="flex gap-3">
            <span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-neutral-950"></span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
      {item.tech && (
        <div class="mt-6 flex flex-wrap gap-2">
          {item.tech.map((technology) => (
            <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-700">{technology}</span>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
